# --- Identity stub (v0 — REPLACE BEFORE PROD) -------------------------------
HIVE_MIND__IDENTITY__PRINCIPAL=local-dev
HIVE_MIND__IDENTITY__ROLES=admin,reader
HIVE_MIND__TENANT=default

# --- Storage ----------------------------------------------------------------
HIVE_MIND__POSTGRES__URL=postgresql://hive:hive@postgres:5432/hivemind
HIVE_MIND__QDRANT__URL=http://qdrant:6333
HIVE_MIND__VALKEY__URL=redis://valkey:6379/0

# --- Model providers --------------------------------------------------------
# The v0 stack ships its own Ollama service in compose at http://ollama:11434.
# The configured embedding model is pulled on first start of that container.
HIVE_MIND__OLLAMA__BASE_URL=http://ollama:11434
HIVE_MIND__OLLAMA__EMBEDDING_MODEL=nomic-embed-text

# Optional alternatives (uncomment + set as needed):
#   * Host Ollama via Docker Desktop:    http://host.docker.internal:11434
#   * Ollama Cloud (chat-only in v0):    https://ollama.com   (see note below)
# HIVE_MIND__OLLAMA__BASE_URL=http://host.docker.internal:11434

# Ollama Cloud API key. The thin MVP does NOT use Cloud for embeddings — Cloud
# gates /api/embed on the reference account (see
# openspec/changes/bootstrap-thin-mvp/design.md D1). The key is reserved for
# follow-up changes that introduce chat / intent / generation paths.
# SECRET — never commit.
# HIVE_MIND__OLLAMA__API_KEY=

# Anthropic key is optional in MVP (used in follow-ups for intent + generation).
# ANTHROPIC_API_KEY=

# --- Service URLs (compose-internal) ---------------------------------------
HIVE_MIND__PIPELINE__URL=http://pipeline:8000
HIVE_MIND__MCP__PORT=8080
HIVE_MIND__ADMIN_UI__URL=http://admin-ui:3000

# --- Observability ----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAMESPACE=hive-mind
# OTEL_LOG_LEVEL=debug

# --- Retrieval defaults -----------------------------------------------------
HIVE_MIND__RETRIEVAL__DEFAULT_TOP_K=20
HIVE_MIND__RETRIEVAL__DEFAULT_TOKEN_BUDGET=4000
